{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Modbus.Desktop",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Modbus.Desktop/bin/Debug/net8.0/Modbus.Desktop.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Modbus.Desktop",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Android: Build + Deploy + Run (Genymotion/USB)",
            "type": "node-terminal",
            "request": "launch",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/scripts/run-android-avalonia.ps1\"",
            "cwd": "${workspaceFolder}"
        }
    ]
}
