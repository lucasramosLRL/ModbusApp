<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modbus.Desktop.ViewModels"
        x:Class="Modbus.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ModbusApp"
        Width="1300" Height="810"
        MinWidth="1300" MinHeight="810"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/app.ico">

    <Grid ColumnDefinitions="220,*" Background="{DynamicResource BrushCanvas}">

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource BrushBgDark}">
            <DockPanel>

                <!-- App title -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="ModbusApp"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeAppTitle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AppSubtitle}"
                                   Foreground="{DynamicResource BrushTextSubtle}"
                                   FontSize="{StaticResource FontSizeLabelSmall}" />
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BrushBgSeparator}" Margin="16,0" />

                <!-- Nav items -->
                <ListBox Background="Transparent"
                         Margin="8,8,8,0"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="CornerRadius" Value="{StaticResource RadiusCardSmall}" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextSubtle}" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BrushBgElevated}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BrushBgSelected}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavItem}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="{StaticResource FontSizeGroupHeader}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}"
                                           FontSize="{StaticResource FontSizeSectionTitle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />

    </Grid>
</Window>
