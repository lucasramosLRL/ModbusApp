<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.DeviceConfigureView"
             x:DataType="vm:DeviceConfigureViewModel">

    <DockPanel Margin="{StaticResource MarginView}">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding GoBackCommand}"
                    Padding="{StaticResource PaddingButtonSmall}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding [ConfigureTitle], Source={x:Static svc:LocalizationService.Instance}}"
                           Classes="page-title" />
                <TextBlock Text="{Binding Device.Name}"
                           FontSize="{StaticResource FontSizeMeta}"
                           Opacity="0.55" />
            </StackPanel>
        </Grid>

        <!-- Device info strip: always visible regardless of selected section -->
        <Border DockPanel.Dock="Top"
                Classes="card"
                Padding="16,10"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="40">
                <StackPanel Spacing="2">
                    <TextBlock Classes="label-small"
                               Text="{Binding [Model], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Text="{Binding Device.ModelDisplayName}"
                               FontSize="{StaticResource FontSizeSectionTitle}"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="label-small"
                               Text="{Binding [CfgSerial], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Text="{Binding SerialNumberText}"
                               FontSize="{StaticResource FontSizeSectionTitle}"
                               FontWeight="Medium"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="label-small"
                               Text="{Binding [CfgFirmware], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Text="{Binding FirmwareText}"
                               FontSize="{StaticResource FontSizeSectionTitle}"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="label-small"
                               Text="{Binding [CfgHardware], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Text="{Binding HardwareText}"
                               FontSize="{StaticResource FontSizeSectionTitle}"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Sidebar + content -->
        <Grid ColumnDefinitions="200,*">

            <!-- Left nav sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushBgDark}"
                    CornerRadius="{StaticResource RadiusCard}"
                    Margin="0,0,16,0">
                <ListBox Background="Transparent"
                         Margin="6"
                         SelectedIndex="{Binding SelectedSectionIndex}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding"      Value="12,10" />
                            <Setter Property="CornerRadius" Value="{StaticResource RadiusCardSmall}" />
                            <Setter Property="Foreground"   Value="{StaticResource BrushTextSubtle}" />
                            <Setter Property="FontSize"     Value="{StaticResource FontSizeSectionTitle}" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource BrushBgElevated}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource BrushBgSelected}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBoxItem Content="{Binding [CfgGeneral],      Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgEthernet],     Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgWireless],     Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgSntp],         Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgIot],          Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgClock],        Source={x:Static svc:LocalizationService.Instance}}" />
                    <ListBoxItem Content="{Binding [CfgInputsOutputs],Source={x:Static svc:LocalizationService.Instance}}" />
                </ListBox>
            </Border>

            <!-- Right content area -->
            <ScrollViewer Grid.Column="1">
                <StackPanel>

                    <!-- ── Configurações Gerais ──────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsGeneral}">
                        <StackPanel Spacing="20">
                            <TextBlock Text="{Binding [CfgGeneral], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- Device info row: Código (read-only) + Endereço (editable) -->
                            <Grid ColumnDefinitions="Auto,140,*" RowDefinitions="Auto">
                                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Top">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgCode], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <TextBlock Text="{Binding DeviceCodeDisplay}"
                                               FontSize="{StaticResource FontSizeSectionTitle}"
                                               FontWeight="Medium"
                                               FontFamily="Consolas, Courier New, monospace"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="24,0,0,0">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [SlaveAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <NumericUpDown Value="{Binding EditableSlaveId, Mode=TwoWay}"
                                                   Minimum="1" Maximum="247" Increment="1"
                                                   FormatString="0"
                                                   HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- Descrição -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label-small"
                                           Text="{Binding [CfgDeviceDesc], Source={x:Static svc:LocalizationService.Instance}}" />
                                <TextBox Text="{Binding Description, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- TP / TC / KE / Tipo de Ligação -->
                            <Grid ColumnDefinitions="*,*,*,2*" RowDefinitions="Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="label-small" Text="TP  (0,01 – 9999,99)" />
                                    <NumericUpDown Minimum="0.01" Maximum="9999.99" Increment="1"
                                                   FormatString="F2" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Classes="label-small" Text="TC  (0,01 – 9999,99)" />
                                    <NumericUpDown Minimum="0.01" Maximum="9999.99" Increment="1"
                                                   FormatString="F2" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Classes="label-small" Text="KE  (0 – 65535)" />
                                    <NumericUpDown Minimum="0" Maximum="65535" Increment="1"
                                                   FormatString="0" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgConnectionType], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <ComboBox HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="00 – Trifásico Estrela 3E 4F" />
                                        <ComboBoxItem Content="01 – Trifásico Triângulo 2E 3F" />
                                        <ComboBoxItem Content="02 – Trifásico Triângulo 3E 3F" />
                                        <ComboBoxItem Content="03 – Bifásico" />
                                        <ComboBoxItem Content="04 – Monofásico" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- TI + Inverter corrente -->
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgIntegrationTime], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <NumericUpDown Minimum="0" Maximum="60" Increment="1"
                                                   FormatString="0" Width="120" />
                                </StackPanel>
                                <CheckBox Content="{Binding [CfgCurrentInvert], Source={x:Static svc:LocalizationService.Instance}}"
                                          VerticalAlignment="Bottom"
                                          Foreground="{StaticResource BrushTextPrimary}" />
                            </StackPanel>

                            <!-- Seq. PF — all 4 ComboBoxes share AllPfBytes; selecting a value
                                 automatically swaps it with whichever position had it before -->
                            <StackPanel Spacing="6">
                                <TextBlock Classes="label-small"
                                           Text="{Binding [CfgPfSequence], Source={x:Static svc:LocalizationService.Instance}}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ComboBox Width="80"
                                              ItemsSource="{Binding AllPfBytes}"
                                              SelectedItem="{Binding PfPos0, Mode=TwoWay}" />
                                    <ComboBox Width="80"
                                              ItemsSource="{Binding AllPfBytes}"
                                              SelectedItem="{Binding PfPos1, Mode=TwoWay}" />
                                    <ComboBox Width="80"
                                              ItemsSource="{Binding AllPfBytes}"
                                              SelectedItem="{Binding PfPos2, Mode=TwoWay}" />
                                    <ComboBox Width="80"
                                              ItemsSource="{Binding AllPfBytes}"
                                              SelectedItem="{Binding PfPos3, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- Horímetro -->
                            <TextBlock Text="{Binding [TabHourmeter], Source={x:Static svc:LocalizationService.Instance}}"
                                       FontSize="{StaticResource FontSizeSectionTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       Opacity="0.7" />
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label-small"
                                           Text="{Binding [CfgThreshold], Source={x:Static svc:LocalizationService.Instance}}" />
                                <NumericUpDown Minimum="0.01" Maximum="9999.99" Increment="0.01"
                                               FormatString="F2" Width="180" HorizontalAlignment="Left" />
                            </StackPanel>


                        </StackPanel>
                    </Border>

                    <!-- ── Ethernet ──────────────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsEthernet}">
                        <StackPanel Spacing="20">
                            <TextBlock Text="{Binding [CfgEthernet], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- DHCP -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label-small" Text="DHCP" />
                                <ComboBox Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="OFF" />
                                    <ComboBoxItem Content="ON" />
                                </ComboBox>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- IP / Mask / Gateway -->
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgIpAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <TextBox Watermark="0.0.0.0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgSubnetMask], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <TextBox Watermark="255.255.255.0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgGateway], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <TextBox Watermark="0.0.0.0" />
                                </StackPanel>
                            </Grid>

                            <!-- MAC Address (read-only) -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label-small"
                                           Text="{Binding [CfgMacAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                <TextBox IsReadOnly="True"
                                         Watermark="—"
                                         FontFamily="Consolas, Courier New, monospace"
                                         Opacity="0.65"
                                         HorizontalAlignment="Left"
                                         Width="220" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- DNS -->
                            <StackPanel Spacing="8">
                                <CheckBox Content="{Binding [CfgDns], Source={x:Static svc:LocalizationService.Instance}}"
                                          Foreground="{StaticResource BrushTextPrimary}" />
                                <TextBox Watermark="208.67.222.222"
                                         HorizontalAlignment="Left"
                                         Width="200" />
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- ── Sem fio ────────────────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsWireless}">
                        <StackPanel Spacing="20">
                            <TextBlock Text="{Binding [CfgWireless], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- Active mode selector -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label-small"
                                           Text="{Binding [CfgMode], Source={x:Static svc:LocalizationService.Instance}}" />
                                <ComboBox Width="240" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="{Binding [CfgDisabled], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <ComboBoxItem Content="Wi-Fi" />
                                    <ComboBoxItem Content="Bluetooth" />
                                    <ComboBoxItem Content="Wi-Fi + Bluetooth" />
                                </ComboBox>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- Wi-Fi + Bluetooth side by side -->
                            <Grid ColumnDefinitions="*,16,*">

                                <!-- Wi-Fi -->
                                <Border Grid.Column="0"
                                        Background="{StaticResource BrushBgElevated}"
                                        CornerRadius="{StaticResource RadiusCardSmall}"
                                        Padding="16">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Wi-Fi"
                                                   FontSize="{StaticResource FontSizeSectionTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   Opacity="0.7" />

                                        <!-- SSID + Security + Password -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small" Text="SSID" />
                                            <TextBox />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgWifiPassword], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBox PasswordChar="•" />
                                        </StackPanel>

                                        <!-- Module version (read-only) -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgModuleVersion], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBlock Text="—"
                                                       FontSize="{StaticResource FontSizeSectionTitle}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       Opacity="0.45" />
                                        </StackPanel>

                                        <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                                        <!-- IP / Mask / Gateway -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgIpAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBox Watermark="0.0.0.0" />
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Classes="label-small"
                                                           Text="{Binding [CfgSubnetMask], Source={x:Static svc:LocalizationService.Instance}}" />
                                                <TextBox Watermark="255.255.255.0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4" Margin="10,0,0,0">
                                                <TextBlock Classes="label-small"
                                                           Text="{Binding [CfgGateway], Source={x:Static svc:LocalizationService.Instance}}" />
                                                <TextBox Watermark="0.0.0.0" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- MAC + DHCP -->
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Classes="label-small"
                                                           Text="{Binding [CfgMacAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                                <TextBlock Text="—"
                                                           FontFamily="Consolas, Courier New, monospace"
                                                           FontSize="{StaticResource FontSizeSectionTitle}"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource BrushTextPrimary}"
                                                           Opacity="0.45" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4" Margin="10,0,0,0">
                                                <TextBlock Classes="label-small" Text="DHCP" />
                                                <ComboBox HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="OFF" />
                                                    <ComboBoxItem Content="ON" />
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- DNS -->
                                        <StackPanel Spacing="6">
                                            <CheckBox Content="{Binding [CfgDns], Source={x:Static svc:LocalizationService.Instance}}"
                                                      Foreground="{StaticResource BrushTextPrimary}" />
                                            <TextBox Watermark="208.67.222.222" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Bluetooth -->
                                <Border Grid.Column="2"
                                        Background="{StaticResource BrushBgElevated}"
                                        CornerRadius="{StaticResource RadiusCardSmall}"
                                        Padding="16">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Bluetooth"
                                                   FontSize="{StaticResource FontSizeSectionTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   Opacity="0.7" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgDeviceDesc], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBox />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgBtPassword], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBox />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="label-small"
                                                       Text="{Binding [CfgMacAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                                            <TextBlock Text="—"
                                                       FontFamily="Consolas, Courier New, monospace"
                                                       FontSize="{StaticResource FontSizeSectionTitle}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       Opacity="0.45" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── SNTP ──────────────────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsSntp}">
                        <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding [CfgSntp], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- Form grid: label | control | unit -->
                            <Grid ColumnDefinitions="180,160,*" RowDefinitions="Auto,14,Auto,14,Auto,14,Auto">

                                <!-- SNTP enabled -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Classes="label-small"
                                           Text="{Binding [CfgSntp], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="{Binding [CfgEnabled],  Source={x:Static svc:LocalizationService.Instance}}" />
                                    <ComboBoxItem Content="{Binding [CfgDisabled], Source={x:Static svc:LocalizationService.Instance}}" />
                                </ComboBox>

                                <!-- Timezone -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Classes="label-small"
                                           Text="{Binding [CfgTimezone], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="2" Grid.Column="1"
                                               Minimum="-12" Maximum="14" Increment="1"
                                               FormatString="0" HorizontalAlignment="Stretch" />
                                <TextBlock Grid.Row="2" Grid.Column="2"
                                           Classes="label-small"
                                           Text="{Binding [CfgUnitHours], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />

                                <!-- Sync interval -->
                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Classes="label-small"
                                           Text="{Binding [CfgSyncInterval], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="4" Grid.Column="1"
                                               Minimum="1" Maximum="1440" Increment="1"
                                               FormatString="0" HorizontalAlignment="Stretch" />
                                <TextBlock Grid.Row="4" Grid.Column="2"
                                           Classes="label-small"
                                           Text="{Binding [CfgUnitMinutes], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />

                                <!-- NTP Server -->
                                <TextBlock Grid.Row="6" Grid.Column="0"
                                           Classes="label-small"
                                           Text="{Binding [CfgNtpServer], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="6" Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Watermark="a.st1.ntp.br" />

                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── IoT ───────────────────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsIot}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="{Binding [CfgIot], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- Top bar: IoT status | interval | send on hour | clear buffer -->
                            <Grid ColumnDefinitions="Auto,24,Auto,*">
                                <!-- IoT status -->
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="label-small" Text="IoT" />
                                    <ComboBox Width="160">
                                        <ComboBoxItem Content="{Binding [CfgEnabled],  Source={x:Static svc:LocalizationService.Instance}}" />
                                        <ComboBoxItem Content="{Binding [CfgDisabled], Source={x:Static svc:LocalizationService.Instance}}" />
                                    </ComboBox>
                                </StackPanel>
                                <!-- Send interval -->
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgSendInterval], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <NumericUpDown Minimum="1" Maximum="1440" Increment="1"
                                                       FormatString="0" Width="100" />
                                        <TextBlock Classes="label-small"
                                                   Text="{Binding [CfgUnitMinutes], Source={x:Static svc:LocalizationService.Instance}}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                <!-- Send on hour + Clear Buffer -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Spacing="20" VerticalAlignment="Bottom">
                                    <CheckBox Content="{Binding [CfgSendOnHour], Source={x:Static svc:LocalizationService.Instance}}"
                                              Foreground="{StaticResource BrushTextPrimary}" />
                                    <Button Content="{Binding [CfgClearBuffer], Source={x:Static svc:LocalizationService.Instance}}"
                                            Padding="{StaticResource PaddingButtonSmall}" />
                                </StackPanel>
                            </Grid>

                            <!-- Sub-tabs: MQTT | Certificados | Retransmitir blocos -->
                            <TabControl MinHeight="320">

                                <!-- MQTT tab -->
                                <TabItem Header="MQTT">
                                    <StackPanel Spacing="16" Margin="0,12,0,0">

                                        <!-- Form: label | control, with checkboxes on the right -->
                                        <Grid ColumnDefinitions="*,Auto">

                                            <!-- Left: form fields -->
                                            <Grid Grid.Column="0"
                                                  ColumnDefinitions="140,*"
                                                  RowDefinitions="Auto,10,Auto,10,Auto,10,Auto,10,Auto,10,Auto,10,Auto">

                                                <!-- Broker -->
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttBroker], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="{Binding [CfgBrokerDefault], Source={x:Static svc:LocalizationService.Instance}}" />
                                                    <ComboBoxItem Content="AWS" />
                                                </ComboBox>

                                                <!-- URL -->
                                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label-small"
                                                           Text="URL"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Watermark="broker.emqx.io" />

                                                <!-- Descrição / ID -->
                                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttDescId], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="4" Grid.Column="1" />

                                                <!-- Porta -->
                                                <TextBlock Grid.Row="6" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttPort], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <NumericUpDown Grid.Row="6" Grid.Column="1"
                                                               Minimum="1" Maximum="65535" Increment="1"
                                                               FormatString="0" HorizontalAlignment="Left" Width="120" />

                                                <!-- Tópico -->
                                                <TextBlock Grid.Row="8" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttTopic], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="8" Grid.Column="1" />

                                                <!-- Nome de usuário -->
                                                <TextBlock Grid.Row="10" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttUser], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="10" Grid.Column="1" />

                                                <!-- Token / Senha -->
                                                <TextBlock Grid.Row="12" Grid.Column="0" Classes="label-small"
                                                           Text="{Binding [CfgMqttToken], Source={x:Static svc:LocalizationService.Instance}}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="12" Grid.Column="1" PasswordChar="•" />

                                            </Grid>

                                            <!-- Right: option checkboxes -->
                                            <StackPanel Grid.Column="1" Spacing="10" Margin="32,0,0,0"
                                                        VerticalAlignment="Top">
                                                <CheckBox Content="{Binding [CfgKeepAlive], Source={x:Static svc:LocalizationService.Instance}}"
                                                          Foreground="{StaticResource BrushTextPrimary}" />
                                                <CheckBox Content="{Binding [CfgKronCloud], Source={x:Static svc:LocalizationService.Instance}}"
                                                          Foreground="{StaticResource BrushTextPrimary}" />
                                                <CheckBox Content="{Binding [CfgTls], Source={x:Static svc:LocalizationService.Instance}}"
                                                          Foreground="{StaticResource BrushTextPrimary}" />
                                            </StackPanel>

                                        </Grid>
                                    </StackPanel>
                                </TabItem>

                                <!-- Certificados tab -->
                                <TabItem Header="{Binding [CfgIotTabCerts], Source={x:Static svc:LocalizationService.Instance}}">
                                    <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                                               Opacity="0.45"
                                               FontSize="{StaticResource FontSizeSectionTitle}"
                                               Margin="0,16,0,0" />
                                </TabItem>

                                <!-- Retransmitir blocos tab -->
                                <TabItem Header="{Binding [CfgIotTabRetransmit], Source={x:Static svc:LocalizationService.Instance}}">
                                    <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                                               Opacity="0.45"
                                               FontSize="{StaticResource FontSizeSectionTitle}"
                                               Margin="0,16,0,0" />
                                </TabItem>

                            </TabControl>

                            <Border Height="1" Background="{StaticResource BrushBgSeparator}" Margin="-16,0" />

                            <!-- Variable selection panel -->
                            <Grid ColumnDefinitions="*,48,*" MinHeight="180">

                                <!-- Available registers -->
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgAvailableRegisters], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <ListBox Background="{StaticResource BrushBgElevated}"
                                             CornerRadius="{StaticResource RadiusCardSmall}"
                                             Padding="4" />
                                </StackPanel>

                                <!-- Transfer buttons -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <Button Content="→" Width="36" HorizontalContentAlignment="Center" />
                                    <Button Content="←" Width="36" HorizontalContentAlignment="Center" />
                                    <Button Content="✕" Width="36" HorizontalContentAlignment="Center" Opacity="0.7" />
                                </StackPanel>

                                <!-- Selected registers -->
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Classes="label-small"
                                               Text="{Binding [CfgSelectedRegisters], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <ListBox Background="{StaticResource BrushBgElevated}"
                                             CornerRadius="{StaticResource RadiusCardSmall}"
                                             Padding="4" />
                                </StackPanel>

                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Relógio ────────────────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsClock}">
                        <StackPanel Spacing="20" MaxWidth="400" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding [CfgClock], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <!-- Form grid: label | control -->
                            <Grid ColumnDefinitions="80,200"
                                  RowDefinitions="Auto,12,Auto,16,Auto">

                                <!-- Data -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label-small"
                                           Text="{Binding [CfgDate], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <DatePicker Grid.Row="0" Grid.Column="1"
                                            HorizontalAlignment="Stretch" />

                                <!-- Hora -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label-small"
                                           Text="{Binding [CfgTime], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <TimePicker Grid.Row="2" Grid.Column="1"
                                            HorizontalAlignment="Stretch" />

                                <!-- Sync source radio buttons -->
                                <StackPanel Grid.Row="4" Grid.Column="1"
                                            Orientation="Horizontal" Spacing="20">
                                    <RadioButton Content="{Binding [CfgManual], Source={x:Static svc:LocalizationService.Instance}}"
                                                 GroupName="ClockSync"
                                                 Foreground="{StaticResource BrushTextPrimary}" />
                                    <RadioButton Content="PC"
                                                 GroupName="ClockSync"
                                                 IsChecked="True"
                                                 Foreground="{StaticResource BrushTextPrimary}" />
                                </StackPanel>

                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Entradas e Saídas ──────────────────────────────── -->
                    <Border Classes="card" IsVisible="{Binding IsInputsOutputs}">
                        <StackPanel Spacing="20" MaxWidth="400" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding [CfgInputsOutputs], Source={x:Static svc:LocalizationService.Instance}}"
                                       Classes="section-title" />

                            <Grid ColumnDefinitions="160,120,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Classes="label-small"
                                           Text="{Binding [CfgDebounceEdp], Source={x:Static svc:LocalizationService.Instance}}"
                                           VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1"
                                               Minimum="0" Maximum="9999" Increment="1"
                                               FormatString="0" HorizontalAlignment="Stretch" />
                                <TextBlock Grid.Column="2" Classes="label-small"
                                           Text="ms"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</UserControl>
