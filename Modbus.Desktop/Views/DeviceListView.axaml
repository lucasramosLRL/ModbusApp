<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             x:Class="Modbus.Desktop.Views.DeviceListView"
             x:DataType="vm:DeviceListViewModel">

    <DockPanel Margin="28,20">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
            <TextBlock Text="Devices"
                       FontSize="26"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="+ Add Device"
                    Command="{Binding OpenAddDeviceCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="Refresh"
                    Command="{Binding LoadDevicesCommand}"
                    Padding="16,8" />
        </Grid>

        <!-- Loading bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,12" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="No devices found. Add a device to get started."
                   IsVisible="{Binding !Devices.Count}"
                   Opacity="0.5"
                   HorizontalAlignment="Center"
                   Margin="0,40" />

        <!-- Device list -->
        <ScrollViewer>
            <ItemsControl x:Name="DeviceList" ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                        <Border Padding="16"
                                Margin="0,0,0,8"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#E0E0E0"
                                Background="White">
                            <Grid ColumnDefinitions="*,Auto">

                                <!-- Left: device info -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ConnectionAddress}"
                                               FontSize="13"
                                               Opacity="0.65" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding TransportType}"
                                                   FontSize="12"
                                                   Opacity="0.55" />
                                        <TextBlock Text="·" Opacity="0.35" />
                                        <TextBlock Text="{Binding ModelName, FallbackValue='Unknown model'}"
                                                   FontSize="12"
                                                   Opacity="0.55" />
                                        <TextBlock Text="·" Opacity="0.35" />
                                        <TextBlock Text="Slave " FontSize="12" Opacity="0.55" />
                                        <TextBlock Text="{Binding SlaveId}" FontSize="12" Opacity="0.55" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: status + open -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Spacing="8">
                                    <TextBlock Text="{Binding StatusText}"
                                               HorizontalAlignment="Right"
                                               FontSize="13"
                                               FontWeight="Medium" />
                                    <TextBlock Text="{Binding LastSeenAt, StringFormat='{}{0:HH:mm:ss}', FallbackValue='Never seen'}"
                                               FontSize="11"
                                               Opacity="0.6"
                                               HorizontalAlignment="Right" />
                                    <Button Content="Open →"
                                            HorizontalAlignment="Right"
                                            Padding="12,6"
                                            Command="{Binding #DeviceList.DataContext.OpenDeviceDetailCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
