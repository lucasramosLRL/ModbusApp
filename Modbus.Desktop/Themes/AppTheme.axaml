<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme-variant colors and brushes live in /Themes/Colors.axaml
         (merged into Application.Resources). Reference those brushes with
         DynamicResource so they swap live when the theme variant changes. -->

    <Styles.Resources>

        <!-- ── Corner Radii ──────────────────────────────────────────────── -->
        <CornerRadius x:Key="RadiusCard">8</CornerRadius>
        <CornerRadius x:Key="RadiusCardSmall">6</CornerRadius>
        <CornerRadius x:Key="RadiusCardLarge">10</CornerRadius>

        <!-- ── Thickness / Padding ───────────────────────────────────────── -->
        <Thickness x:Key="PaddingCard">16</Thickness>
        <Thickness x:Key="PaddingCardHub">20</Thickness>
        <Thickness x:Key="PaddingButton">16,8</Thickness>
        <Thickness x:Key="PaddingButtonSmall">12,8</Thickness>
        <Thickness x:Key="MarginView">28,20</Thickness>

        <!-- ── Font Sizes ────────────────────────────────────────────────── -->
        <!-- Large titles kept as-is; smaller body/meta/label tiers bumped +1
             so secondary text reads larger (was perceived as too small). -->
        <x:Double x:Key="FontSizeMainTitle">26</x:Double>
        <x:Double x:Key="FontSizePageTitle">24</x:Double>
        <x:Double x:Key="FontSizeAppTitle">18</x:Double>
        <x:Double x:Key="FontSizeCardTitle">17</x:Double>
        <x:Double x:Key="FontSizeGroupHeader">16</x:Double>
        <x:Double x:Key="FontSizeSectionTitle">14</x:Double>
        <x:Double x:Key="FontSizeMeta">13</x:Double>
        <x:Double x:Key="FontSizeLabelSmall">12</x:Double>

    </Styles.Resources>

    <!-- ── Component Styles ──────────────────────────────────────────────── -->

    <!-- Standard card: surface background, rounded corners, standard padding.
         BorderBrush is invisible in dark (== background) and a subtle outline in
         light (BrushCardBorder) so cards stay defined on the light-gray canvas. -->
    <Style Selector="Border.card">
        <Setter Property="Background"       Value="{DynamicResource BrushBgDark}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BrushCardBorder}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource RadiusCard}"/>
        <Setter Property="Padding"          Value="{StaticResource PaddingCard}"/>
    </Style>

    <!-- Hub feature card: larger padding and corner radius -->
    <Style Selector="Border.card-hub">
        <Setter Property="Background"       Value="{DynamicResource BrushBgDark}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BrushCardBorder}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource RadiusCardLarge}"/>
        <Setter Property="Padding"          Value="{StaticResource PaddingCardHub}"/>
    </Style>

    <!-- Reading group container: elevated background, card radius -->
    <Style Selector="Border.reading-group">
        <Setter Property="Background"   Value="{DynamicResource BrushBgElevated}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}"/>
        <Setter Property="Padding"      Value="{StaticResource PaddingCard}"/>
    </Style>

    <!-- Individual electrical reading value box -->
    <Style Selector="Border.reading-box">
        <Setter Property="Background"   Value="{DynamicResource BrushBgDark}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCardSmall}"/>
        <Setter Property="Padding"      Value="14,10"/>
    </Style>

    <!-- Page title: 24pt SemiBold (DeviceDetail, DeviceHub, AddDevice headers) -->
    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Main title: 26pt SemiBold (DeviceList, Settings headers) -->
    <Style Selector="TextBlock.main-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMainTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Section title inside a card: 13pt SemiBold white -->
    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSectionTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>

    <!-- Small label above a form field: 11pt dimmed white -->
    <Style Selector="TextBlock.label-small">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLabelSmall}"/>
        <Setter Property="Opacity"    Value="0.55"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>

    <!-- Invalid input border: applied via Classes.invalid="{Binding HasInvalidXxx}".
         Used by the config screen IP fields so the user can see at a glance which
         field is blocking the Save button. -->
    <Style Selector="TextBox.invalid">
        <Setter Property="BorderBrush"     Value="#C24040"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>
    <Style Selector="TextBox.invalid:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush"     Value="#C24040"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

</Styles>
