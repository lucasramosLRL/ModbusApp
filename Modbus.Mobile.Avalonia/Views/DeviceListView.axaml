<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modbus.Mobile.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="Modbus.Mobile.Avalonia.Views.DeviceListView"
             x:DataType="vm:DeviceListViewModel">

    <Panel>
        <DockPanel Margin="16">

            <!-- Header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Text="Dispositivos" FontSize="22" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Adicionar"
                        Command="{Binding OpenAddDeviceCommand}"
                        Padding="14,8"/>
            </Grid>

            <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}" Height="3" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" Text="Nenhum dispositivo cadastrado"
                       IsVisible="{Binding !Devices.Count}"
                       Opacity="0.5" HorizontalAlignment="Center" Margin="0,40"/>

            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                            <Border Background="#11000000" CornerRadius="8"
                                    Padding="14" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ConnectionAddress}" FontSize="13" Opacity="0.65"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding TransportTypeDisplay}" FontSize="12" Opacity="0.55"/>
                                            <TextBlock Text="·" Opacity="0.35"/>
                                            <TextBlock Text="{Binding ModelDisplayName}" FontSize="12" Opacity="0.55"/>
                                            <TextBlock Text="·" Opacity="0.35"/>
                                            <TextBlock Text="{Binding SlaveIdText}" FontSize="12" Opacity="0.55"/>
                                            <TextBlock Text="·" Opacity="0.35"
                                                       IsVisible="{Binding FirmwareText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding FirmwareText}" FontSize="12" Opacity="0.55"
                                                       IsVisible="{Binding FirmwareText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                HorizontalAlignment="Right" Spacing="6">
                                        <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="Medium"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding LastSeenText}" FontSize="11" Opacity="0.6"
                                                   HorizontalAlignment="Right"/>
                                        <Button Content="Excluir" Padding="10,5" HorizontalAlignment="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:DeviceListViewModel)DataContext).RequestDeleteCommand}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Delete confirmation overlay -->
        <Border Background="#99000000" IsVisible="{Binding HasPendingDelete}">
            <Border Background="#2B2B2B" CornerRadius="10" Padding="20"
                    Width="300" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="18">
                    <TextBlock Text="Excluir dispositivo?" FontSize="17" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding PendingDelete.Name, StringFormat='Remover {0}? Esta ação não pode ser desfeita.'}"
                               TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Cancelar" Padding="14,8" Command="{Binding CancelDeleteCommand}"/>
                        <Button Content="Excluir" Padding="14,8" Background="#C0392B" Foreground="White"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
