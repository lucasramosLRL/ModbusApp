<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modbus.Mobile.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="Modbus.Mobile.Avalonia.Views.AddDeviceView"
             x:DataType="vm:AddDeviceViewModel">

    <DockPanel Margin="16">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
            <Button Content="‹ Voltar" Command="{Binding GoBackCommand}" Padding="10,6"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Adicionar dispositivo" FontSize="20" FontWeight="SemiBold"
                       Margin="12,0" VerticalAlignment="Center"/>
        </Grid>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsSaving}" Height="3" Margin="0,0,0,6"/>

        <ScrollViewer>
            <StackPanel Spacing="14">

                <!-- Transport -->
                <Border Background="#11000000" CornerRadius="8" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Transporte" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <RadioButton Content="TCP" GroupName="transport"
                                         IsChecked="{Binding IsTcp, Mode=TwoWay}"/>
                            <RadioButton Content="Nuvem (MQTT)" GroupName="transport"
                                         IsChecked="{Binding IsCloud}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- TCP panel -->
                <Border Background="#11000000" CornerRadius="8" Padding="14" IsVisible="{Binding IsTcp}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Buscar na rede" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Buscar" Command="{Binding ScanCommand}" Padding="14,8"/>
                            <Button Content="Cancelar" Command="{Binding CancelScanCommand}" Padding="14,8"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsScanning}" Height="3"/>
                        <TextBlock Text="{Binding ScanStatus}" FontSize="12" Opacity="0.7"/>

                        <ListBox ItemsSource="{Binding ScanResults}"
                                 SelectedItem="{Binding SelectedResult}"
                                 MaxHeight="200" IsVisible="{Binding ScanResults.Count}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ScanResultViewModel}">
                                    <StackPanel Spacing="2" Margin="0,2">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding AddressText}" FontSize="12" Opacity="0.6"/>
                                            <TextBlock Text="·" Opacity="0.3"/>
                                            <TextBlock Text="{Binding SerialText}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="ou informe manualmente" FontSize="12" Opacity="0.5" Margin="0,4,0,0"/>
                        <TextBlock Text="Endereço IP"/>
                        <TextBox Text="{Binding DeviceIp}" Watermark="192.168.0.50"/>
                        <TextBlock Text="Porta"/>
                        <TextBox Text="{Binding TcpPort}" Watermark="502"/>
                    </StackPanel>
                </Border>

                <!-- Cloud panel -->
                <Border Background="#11000000" CornerRadius="8" Padding="14" IsVisible="{Binding IsCloud}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Broker MQTT" FontWeight="SemiBold"/>
                        <TextBlock Text="Host"/>
                        <TextBox Text="{Binding BrokerHost}" Watermark="mqtt.exemplo.com"/>
                        <TextBlock Text="Porta"/>
                        <TextBox Text="{Binding BrokerPort}" Watermark="8883"/>
                        <CheckBox Content="Usar TLS" IsChecked="{Binding BrokerUseTls}"/>
                        <TextBlock Text="Usuário"/>
                        <TextBox Text="{Binding BrokerUsername}"/>
                        <TextBlock Text="Senha"/>
                        <TextBox Text="{Binding BrokerPassword}" PasswordChar="•"/>
                        <TextBlock Text="Número de série"/>
                        <TextBox Text="{Binding CloudSerial}" Watermark="0001234"/>
                        <TextBlock Text="Tópico de telemetria"/>
                        <TextBox Text="{Binding TelemetryTopic}" Watermark="ks"/>
                        <TextBlock Text="Modelo"/>
                        <ComboBox ItemsSource="{Binding AvailableModels}"
                                  SelectedItem="{Binding SelectedModel}" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Common: name + save -->
                <Border Background="#11000000" CornerRadius="8" Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Nome"/>
                        <TextBox Text="{Binding DeviceName}" Watermark="Nome do dispositivo"/>
                        <Button Content="Salvar" Command="{Binding SaveCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,10"/>
                        <TextBlock Text="{Binding SaveFeedback}" TextWrapping="Wrap"
                                   IsVisible="{Binding SaveFeedback, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
