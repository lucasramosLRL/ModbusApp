<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modbus.Mobile.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="Modbus.Mobile.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">

    <DockPanel>
        <!-- Boot error banner (only if Core startup failed) -->
        <Border DockPanel.Dock="Top"
                Background="#D32F2F"
                IsVisible="{Binding BootError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Padding="12,8">
            <TextBlock Text="{Binding BootError}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <ContentControl Content="{Binding CurrentPage}"/>
    </DockPanel>
</UserControl>
